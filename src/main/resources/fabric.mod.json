{
	"schemaVersion": 1,
	"id": "personal_beacon",
	"version": "${version}",
	"name": "Personal Beacon",
	"description": "This mod adds personal beacon with custom effects that is powered by vanilla beacon!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/personal_beacon/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"name.personal_beacon.PersonalBeacon"
		],
		"client": [
			"name.personal_beacon.client.PersonalBeaconClient"
		],
		"modmenu": [
			"name.personal_beacon.client.ModMenuIntegration"
		]
	},
	"mixins": [
		"personal_beacon.mixins.json",
		{
			"config": "personal_beacon.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"trinkets": ">=3.10.0"
	}
}